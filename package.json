{
  "name": "flixview",
  "version": "0.1.6",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop": "electron .",
    "app": "npm run desktop",
    "electron:dev": "concurrently -k \"next dev --webpack\" \"wait-on --interval 2000 http://localhost:3000 && electron .\"",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -wml"
  },
  "build": {
    "appId": "com.flixview.app",
    "productName": "FlixView",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "main.js",
      "preload.js",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE.txt",
      "installerHeaderIcon": "public/icon.png",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "FlixView"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "jumakrk",
      "repo": "FlixView"
    }
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "clsx": "^2.1.1",
    "cross-fetch": "^4.1.0",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
